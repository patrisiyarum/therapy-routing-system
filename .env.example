# Copy to .env and add your OWN keys. Never commit real keys. The app runs
# fully offline with everything blank.

# Anthropic: writes the "why this patient fits" summaries providers read.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
USE_LLM=false

# AWS Location: street-level geocoding. A modern key (v1.public...) does NOT
# need a place index. Just set the key and the region it was created in.
AWS_LOCATION_API_KEY=
AWS_REGION=us-east-1

# matching knobs (optional)
GOLDEN_BONUS=18
DEFAULT_RADIUS_MILES=25
PATIENT_TELEHEALTH_DEFAULT=true
PROVIDER_TELEHEALTH_DEFAULT=true
ACCEPT_UNKNOWN_NETWORK=true
